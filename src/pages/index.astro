---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import MapCallout from '../components/MapCallout.astro';
import Entrance from '../components/sections/Entrance.astro';
import WindingPath from '../components/sections/WindingPath.astro';
import LibraryClearing from '../components/sections/LibraryClearing.astro';
import CommunityMeadow from '../components/sections/CommunityMeadow.astro';
import '../styles/global.css';

const fundingConfig = {
    goal: 600,
    raised: 150, // Example starting value, user can update this
};

const navLinks = [
    { name: 'The Story', href: '#entrance' },
    { name: 'Funding', href: '#path' },
    { name: 'Donate', href: '#clearing' },
    { name: 'Assembly', href: '#meadow' },
];
---

<Layout title="North Park Little Free Library">
	<!-- Navigation -->
	<nav class="fixed top-0 w-full bg-[#006766] shadow-[0_4px_0_0_rgba(93,64,55,0.1)] z-50 transition-all duration-300" id="topNav">
		<div class="flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-unit max-w-[1200px] mx-auto">
			<div class="flex items-center gap-2">
				<span class="material-symbols-outlined text-white text-3xl" data-weight="fill">menu_book</span>
				<span class="font-literata font-bold text-white italic hidden sm:block text-headline-lg-mobile md:text-headline-lg">North Park Little Library</span>
			</div>
			<div class="hidden md:flex items-center gap-6">
				{navLinks.map(link => {
					return (
						<a href={link.href} class="nav-item text-white border-b-2 border-parchment-light pb-1 font-label-bold text-label-bold hover:text-white hover:skew-x-1 transition-transform" id={`nav-${link.href.replace('#', '')}`}>
							{link.name}
						</a>
					);
				})}
			</div>
			<div class="flex items-center gap-3">
				<Button variant="wood" href="https://cash.app/$nplittlelibrary" target="_blank" rel="noopener noreferrer" className="px-4 py-2 rounded font-label-bold text-label-bold text-on-secondary-fixed">Donate</Button>
				<Button variant="paper" href="mailto:Northparklittlelibrary@gmail.com?subject=Volunteer%20to%20Make%20Repairs" className="hidden sm:block px-4 py-2 rounded font-label-bold text-label-bold text-earth-brown hover:bg-surface-variant transition-colors">Volunteer</Button>
			</div>
		</div>
	</nav>

	<!-- Map Background -->
	<div class="absolute top-0 left-0 w-full z-0 pointer-events-none flex justify-center">
		<img alt="Hand-drawn map" class="w-full h-auto max-w-[4000px] block" src="/images/stitch_north_park_library_map.png" />
	</div>

	<main class="relative z-10 w-full max-w-[1200px] mx-auto mt-[80px]">
		<Entrance />
		<WindingPath goal={fundingConfig.goal} raised={fundingConfig.raised} />
		<LibraryClearing />
		<CommunityMeadow />
	</main>

	<footer class="bg-surface-container-highest dark:bg-surface-variant w-full mt-gutter rounded-t-[40px] flex flex-col items-center justify-center py-20 md:py-40 gap-unit border-t-4 border-earth-brown border-dashed relative z-20">
		<div class="font-literata text-headline-lg text-primary italic mb-4">North Park Little Library</div>
		<div class="flex flex-wrap justify-center gap-6 mb-6">
			<a class="font-label-bold text-label-bold text-on-surface-variant hover:text-berry-red underline decoration-wavy transition-colors" href="#">Privacy Policy</a>
			<a class="font-label-bold text-label-bold text-on-surface-variant hover:text-berry-red underline decoration-wavy transition-colors" href="#">Contact Librarian</a>
			<a class="font-label-bold text-label-bold text-on-surface-variant hover:text-berry-red underline decoration-wavy transition-colors" href="#">Visit City Hall</a>
		</div>
		<p class="font-body-md text-body-md text-earth-brown dark:text-on-surface-variant text-center px-4 max-w-md">
			© North Park Little Library. Hand-sketched with care.
		</p>
	</footer>

	<script>
		const sections = document.querySelectorAll("section");
		const navLinks = document.querySelectorAll(".nav-item");
		const topNav = document.getElementById('topNav');

		window.addEventListener("scroll", () => {
			let current = "";
			sections.forEach((section) => {
				const sectionTop = section.offsetTop;
				if (window.scrollY >= sectionTop - 100) {
				current = section.getAttribute("id");
				}
			});

			navLinks.forEach((link) => {
				link.classList.remove("text-white", "border-b-2", "border-parchment-light", "pb-1");
				link.classList.add("text-white/70");
				if (link.getAttribute("href").includes(current)) {
					link.classList.add("text-white", "border-b-2", "border-parchment-light", "pb-1");
				}
			});

			if (window.scrollY > 10) {
				topNav?.classList.add('shadow-md');
				} else {
				topNav?.classList.remove('shadow-md');
			}
		});
	</script>
</Layout>

