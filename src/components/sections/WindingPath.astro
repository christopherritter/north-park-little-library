---
import Card from '../Card.astro';

interface Props {
    goal?: number;
    raised?: number;
}

const { 
    goal = 1000,
    raised = 0
} = Astro.props;

const tiers = [
    { 
        name: "Mini Shed Little Free Library", 
        cost: 189.95, 
        description: "A compact start to our neighborhood's reading journey.",
        image: "https://littlefreelibrary.myshopify.com/cdn/shop/products/MiniShedLittleFreeLibraryResized1.png?v=1631130327&width=1800",
        url: "https://littlefreelibrary.myshopify.com/collections/little-free-libraries/products/mini-shed"
    },
    { 
        name: "Cottage Unfinished Little Free Library", 
        cost: 259.95, 
        description: "Adding more space and a classic cottage charm.",
        image: "https://littlefreelibrary.myshopify.com/cdn/shop/files/UnfinishedCottageLittleFreeLibrary1.png?v=1695418768&width=1080",
        url: "https://littlefreelibrary.myshopify.com/collections/little-free-libraries/products/cozy-cottage"
    },
    { 
        name: "Two Story Shed Unfinished Little Free Library", 
        cost: 299.95, 
        description: "Expanding vertically to house even more community favorites.",
        image: "https://littlefreelibrary.myshopify.com/cdn/shop/products/TwoStoryShedUnfininshedLittleFreeLibrary1.png?v=1586004317&width=1080",
        url: "https://littlefreelibrary.myshopify.com/collections/little-free-libraries/products/amish-two-story"
    },
    { 
        name: "Composite One-Story Library", 
        cost: 349.95, 
        description: "Low maintenance, high durability—built to withstand the elements.",
        image: "https://littlefreelibrary.myshopify.com/cdn/shop/files/Compositeonestoryblue1.png?v=1753995141&width=1080",
        url: "https://littlefreelibrary.myshopify.com/collections/little-free-libraries/products/composite-one-story-blue-little-free-library",
        dependsOn: "Screw In Library Post with Topper"
    },
    { 
        name: "Composite Two-Story Library", 
        cost: 409.95, 
        description: "The gold standard of durability and capacity.",
        image: "https://littlefreelibrary.myshopify.com/cdn/shop/files/Composite_Two_story_Light_Blue_1.png?v=1745269697&width=1080",
        url: "https://littlefreelibrary.myshopify.com/collections/little-free-libraries/products/composite-two-story-blue",
        dependsOn: "Screw In Library Post with Topper"
    },
    { 
        name: "Composite Double Door Library", 
        cost: 439.95, 
        description: "The ultimate community hub for books and connection.",
        image: "https://littlefreelibrary.myshopify.com/cdn/shop/files/CompositeDoubleDoorCottageLittleFreeLibrary1.png?v=1684350755&width=1080",
        url: "https://littlefreelibrary.myshopify.com/collections/little-free-libraries/products/composite-double-door-cottage-blue-little-free-library",
        dependsOn: "Screw In Library Post with Topper"
    },
];

const addOns = [
    { 
        category: "Library Posts", 
        items: [
            { name: "Library Post with Topper", price: "89.95", unlockAt: 89.95, image: "https://littlefreelibrary.myshopify.com/cdn/shop/files/LFLpostkithero21x1.png?v=1706134424&width=1800", url: "https://littlefreelibrary.myshopify.com/collections/all-products/products/library-post-with-topper-kit" },
                { name: "Screw In Library Post with Topper", price: "159.95", unlockAt: 459.90, image: "https://littlefreelibrary.myshopify.com/cdn/shop/products/Little_Free_Library_Screw-In_Library_Post_with_Topper.jpg?v=1621884973&width=1800", url: "https://littlefreelibrary.myshopify.com/collections/all-products/products/screw-in-library-post-with-topper" },
            { name: "Composite Library Post and Topper Kit", price: "129.95", unlockAt: 129.95, image: "https://littlefreelibrary.myshopify.com/cdn/shop/files/CompositePostKitBlackHeroLittleFreeLibrary1x1.png?v=1740681889&width=1800", url: "https://littlefreelibrary.myshopify.com/collections/all-products/products/composite-library-post-and-topper-kit-black", dependsOn: "Screw In Library Post with Topper" },
            { name: "Composite Screen In Library Post and Topper Black", price: "179.95", unlockAt: 179.95, image: "https://littlefreelibrary.myshopify.com/cdn/shop/products/CompositeScrewInLibraryPostandTopper1000x1000.jpg?v=1611765357&width=1800", url: "https://littlefreelibrary.myshopify.com/collections/all-products/products/composite-screw-in-library-post-and-topper-black", dependsOn: "Screw In Library Post with Topper" },
        ] 
    },
    { 
        category: "Charter Signs", 
        items: [
            { name: "Official Charter Sign", price: "49.95", unlockAt: 49.95, image: "https://littlefreelibrary.myshopify.com/cdn/shop/files/CharterSignOfficial1x1.png?v=1708640155&width=1800", url: "https://littlefreelibrary.myshopify.com/collections/all-products/products/silver-aluminum-charter-sign", dependsOn: "Screw In Library Post with Topper" },
            { name: "Little Free Library Custom Charter Sign", price: "79.95", unlockAt: 79.95, image: "https://littlefreelibrary.myshopify.com/cdn/shop/files/CustomCharterSignHeroPhoto1x1.png?v=1708640451&width=1800", url: "https://littlefreelibrary.myshopify.com/collections/all-products/products/custom-aluminum-charter-sign", dependsOn: "Screw In Library Post with Topper" },
        ] 
    },
];

const percentage = Math.min(Math.round((raised / goal) * 100), 100);

const isItemUnlocked = (name) => {
    const item = addOns.flatMap(g => g.items).find(i => i.name === name);
    if (!item) return false;
    const funded = raised >= (item.unlockAt || 0);
    if (!funded) return false;
    if (item.dependsOn) {
        return isItemUnlocked(item.dependsOn);
    }
    return true;
};
---

<section class="relative flex flex-col items-center justify-start pt-32 pb-20 px-margin-mobile md:px-margin-desktop" id="path">
    <div class="w-full max-w-3xl z-10 flex flex-col gap-12">
        <!-- Fundraising Progress Card -->
        <Card variant="paper" className="p-4 md:p-8 shadow-lg border-2 border-earth-brown/20 text-center">
            <h2 class="font-literata text-headline-sm-mobile md:text-headline-lg text-primary mb-2">Neighborhood Restoration Fund</h2>
            <p class="font-body-md-mobile md:font-body-md text-on-surface-variant mb-6 max-w-xl mx-auto">We're raising money together to replace our worn-out Little Free Library. Every donation moves us toward the next tier.</p>
            
            <div class="flex justify-between items-end mb-2 font-label-bold text-label-bold-mobile md:text-label-bold text-primary">
                <span class="text-xl md:text-2xl">${raised} <span class="text-xs md:text-sm opacity-70">raised</span></span>
                <span class="text-xs md:text-sm opacity-70">of ${goal} total goal</span>
            </div>
            <div class="w-full h-6 bg-surface rounded-full overflow-hidden border-2 border-earth-brown shadow-inner">
                <div 
                    class="h-full bg-primary transition-all duration-1000 ease-out relative" 
                    style={`width: ${percentage}%`}
                >
                    <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-primary animate-pulse"></div>
                </div>
            </div>
            <p class="mt-4 text-center font-body-md text-on-surface-variant italic">
                {percentage === 100 ? "All goals reached! Thank you!" : `${goal - raised} more to go for the ultimate community library.`}
            </p>
        </Card>

        <!-- Funding Path Cards -->
        <div class="flex flex-col gap-8">
                {tiers.map((tier, index) => {
                    const isFunded = raised >= tier.cost && (!tier.dependsOn || isItemUnlocked(tier.dependsOn));
                    const rotation = index % 2 === 0 ? 'rotate-1' : '-rotate-1';
                    return (
                    <a href={tier.url} target="_blank" rel="noopener noreferrer" class="block group">
                        <Card 
                            variant="paper" 
                            className={`flex flex-col md:flex-row overflow-hidden border-2 transition-all duration-500 shadow-sm ${rotation} ${isFunded ? 'border-primary opacity-100' : 'border-earth-brown/20 grayscale'} group-hover:shadow-md group-hover:-translate-y-1`}
                        >
                            <div class="w-full md:w-48 h-32 md:h-auto bg-surface-variant relative overflow-hidden">
                                <img 
                                    src={tier.image} 
                                    alt={tier.name} 
                                    class={`w-full h-full object-cover transition-all duration-500 ${isFunded ? 'scale-100' : 'scale-110 grayscale'} group-hover:scale-105`}
                                />
                                {isFunded && (
                                    <div class="absolute top-2 left-2 bg-primary text-white px-2 py-1 rounded text-xs font-label-bold shadow-sm flex items-center gap-1">
                                        <span class="material-symbols-outlined text-xs">check_circle</span> Funded
                                    </div>
                                )}
                            </div>
                            <div class="p-6 flex-1 flex flex-col justify-center">
                                <div class="flex justify-between items-start mb-2">
                                    <span class={`font-literata text-headline-sm transition-colors ${isFunded ? 'text-primary' : 'text-on-surface-variant'} group-hover:text-primary`}>{tier.name}</span>
                                    <span class={`font-label-bold text-label-bold ${isFunded ? 'text-primary' : 'text-on-surface-variant opacity-70'}`}>${tier.cost}</span>
                                </div>
                                <p class="font-body-md text-body-md text-on-surface-variant/80 leading-relaxed">
                                    {tier.description}
                                </p>
                            </div>
                        </Card>
                    </a>
                );
            })}
        </div>

        <!-- Add-Ons Section -->
        <div class="flex flex-col gap-6">
            <div class="flex items-center gap-2 mb-2 transition-all duration-500">
                <h3 class="font-literata text-headline-sm text-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">shopping_basket</span> Community Extras & Add-Ons
                </h3>
            </div>

            <div class="flex flex-col gap-8">
                {addOns.map((group, index) => {
                    return (
                        <Card variant="paper" className={`p-6 border-2 border-earth-brown/20 shadow-sm transition-all duration-500 ${index % 2 === 0 ? 'rotate-1' : '-rotate-1'}`}>
                            <span class="font-label-bold text-primary uppercase text-xs block mb-3">{group.category}</span>
                            <ul class="space-y-2 font-body-md text-on-surface-variant">
                                {group.items.map(item => {
                                    const unlocked = isItemUnlocked(item.name);
                                    return (
                                        <li class={`flex items-center justify-between gap-2 border-l-2 pl-3 py-1 transition-colors ${unlocked ? 'border-primary hover:bg-primary/5' : 'border-earth-brown/20 grayscale opacity-60 pointer-events-none'}`}>
                                            <div class="flex items-center gap-2 overflow-hidden">
                                                {item.image && <img src={item.image} alt="" class="w-8 h-8 object-cover rounded shadow-sm flex-shrink-0" />}
                                                <a href={item.url} target="_blank" rel="noopener noreferrer" class={`transition-colors hover:text-primary ${item.url ? 'text-on-surface-variant' : 'text-on-surface-variant/50 cursor-not-allowed'}`} style={item.url ? {} : {pointerEvents: 'none'}}>
                                                    {item.name}
                                                </a>
                                                {unlocked && (
                                                    <span class="bg-primary text-white px-1.5 py-0.5 rounded text-[10px] font-label-bold shadow-sm flex items-center gap-0.5 ml-1">
                                                        <span class="material-symbols-outlined text-[10px]">check_circle</span> Funded
                                                    </span>
                                                )}
                                            </div>
                                            {item.price && <span class="font-label-bold text-primary text-xs">${item.price}</span>}
                                        </li>
                                    )
                                })}
                            </ul>
                        </Card>
                    )
                })}
            </div>
        </div>
    </div>

    <!-- Visual Path Element -->
    <div class="w-full max-w-lg mx-auto border-l-4 border-dashed border-earth-brown opacity-10 h-96 absolute left-1/2 -translate-x-1/2 rounded-[100px_0_0_100px] pointer-events-none"></div>
</section>
