---
import Card from '../Card.astro';

interface Props {
    goal?: number;
    raised?: number;
}

const { 
    goal = 600,
    raised = 0
} = Astro.props;

const percentage = Math.min(Math.round((raised / goal) * 100), 100);
---

<section class="relative flex flex-col items-center justify-start pt-32 pb-20 px-margin-mobile md:px-margin-desktop" id="path">
    <div class="w-full max-w-3xl z-10 flex flex-col gap-12">
        <!-- Fundraising Progress Card -->
        <Card variant="paper" className="p-8 shadow-lg border-2 border-earth-brown/20 text-center">
            <h2 class="font-literata text-headline-lg text-primary mb-2">Our Restoration Fund</h2>
            <p class="font-body-md text-on-surface-variant mb-6 max-w-xl mx-auto">We're raising funds to replace the decayed structure with something built to last. Every bit helps us reach the Gold Standard.</p>
            
            <div class="flex justify-between items-end mb-2 font-label-bold text-label-bold text-primary">
                <span class="text-2xl">${raised} <span class="text-sm opacity-70">raised</span></span>
                <span class="text-sm opacity-70">of ${goal} goal</span>
            </div>
            <div class="w-full h-6 bg-surface rounded-full overflow-hidden border-2 border-earth-brown shadow-inner">
                <div 
                    class="h-full bg-primary transition-all duration-1000 ease-out relative" 
                    style={`width: ${percentage}%`}
                >
                    <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-primary animate-pulse"></div>
                </div>
            </div>
            <p class="mt-4 text-center font-body-md text-on-surface-variant italic">
                ${percentage === 100 ? "Goal reached! Thank you!" : `${goal - raised} more to go for the Gold Standard library.`}
            </p>
        </Card>

        <!-- Budget Breakdown -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <Card variant="paper" className="p-6 border-l-4 border-primary">
                <h3 class="font-literata text-headline-sm text-primary mb-2 flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">savings</span> The Budget Path
                </h3>
                <p class="text-sm text-on-surface-variant mb-4">A functional, clean replacement to get the community reading again.</p>
                <div class="font-label-bold text-label-bold text-earth-brown bg-surface/50 p-2 rounded text-center border border-dashed border-earth-brown/40">
                    Est. Cost: ~$190 + Post
                </div>
            </Card>

            <Card variant="paper" className="p-6 border-l-4 border-secondary-fixed shadow-md">
                <h3 class="font-literata text-headline-sm text-primary mb-2 flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">stars</span> The Gold Standard
                </h3>
                <p class="text-sm text-on-surface-variant mb-4">Top-of-the-line weatherproofing and materials to last for decades.</p>
                <div class="font-label-bold text-label-bold text-earth-brown bg-secondary-fixed/10 p-2 rounded text-center border border-dashed border-secondary-fixed/40">
                    Est. Cost: ~$449 + Shipping + Post (~$600 Total)
                </div>
            </Card>
        </div>
    </div>

    <!-- Visual Path Element (kept for aesthetic continuity) -->
    <div class="w-full max-w-lg mx-auto border-l-4 border-dashed border-earth-brown opacity-10 h-96 absolute left-1/2 -translate-x-1/2 rounded-[100px_0_0_100px] pointer-events-none"></div>
</section>
