---
import Card from '../Card.astro';

interface Props {
    goal?: number;
    raised?: number;
}

const { 
    goal = 1000,
    raised = 0
} = Astro.props;

const tiers = [
    { name: "Mini Shed Little Free Library", cost: 50 },
    { name: "Cottage Unfinished Little Free Library", cost: 120 },
    { name: "Two Story Shed Unfinished Little Free Library", cost: 180 },
    { name: "Two Story Gable Unfinished Little Free Library", cost: 250 },
    { name: "Double Door Shed Unfinished Little Free Library", cost: 320 },
    { name: "Composite One-Story Library", cost: 420 },
    { name: "Composite Two-Story Library", cost: 520 },
    { name: "Composite Double Door Library", cost: 650 },
];

const addOns = [
    { category: "Charter Signs", items: ["Official Charter Sign", "English-Spanish Bilingual Official Charter Sign", "Custom Little Free Library Charter Sign"] },
    { category: "Posts and Mounting", items: ["Library Post with Topper Kit", "Screw-In Library Post with Topper", "Composite Library Post and Topper Kit Black", "Composite Screw In Library Post and Topper Black"] },
    { category: "Book Support", items: ["Book Bundle Ages 12 and Under (40 Books)", "Book Bundle Kids and Adults Mix (35 Books)"] },
    { category: "Neighborhood Extras", items: ["Seasonal Garden Flag Bundle", "Customizable Artisan Stamp", "Standard Artisan Stamp", "Dog Hook", "Dog Treat Box"] },
];

const percentage = Math.min(Math.round((raised / goal) * 100), 100);
---

<section class="relative flex flex-col items-center justify-start pt-32 pb-20 px-margin-mobile md:px-margin-desktop" id="path">
    <div class="w-full max-w-3xl z-10 flex flex-col gap-12">
        <!-- Fundraising Progress Card -->
        <Card variant="paper" className="p-8 shadow-lg border-2 border-earth-brown/20 text-center">
            <h2 class="font-literata text-headline-lg text-primary mb-2">Neighborhood Restoration Fund</h2>
            <p class="font-body-md text-on-surface-variant mb-6 max-w-xl mx-auto">We're raising money together to replace our worn-out Little Free Library. Every donation moves us toward the next tier.</p>
            
            <div class="flex justify-between items-end mb-2 font-label-bold text-label-bold text-primary">
                <span class="text-2xl">${raised} <span class="text-sm opacity-70">raised</span></span>
                <span class="text-sm opacity-70">of ${goal} total goal</span>
            </div>
            <div class="w-full h-6 bg-surface rounded-full overflow-hidden border-2 border-earth-brown shadow-inner">
                <div 
                    class="h-full bg-primary transition-all duration-1000 ease-out relative" 
                    style={`width: ${percentage}%`}
                >
                    <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-primary animate-pulse"></div>
                </div>
            </div>
            <p class="mt-4 text-center font-body-md text-on-surface-variant italic">
                {percentage === 100 ? "All goals reach! Thank you!" : `${goal - raised} more to go for the ultimate community library.`}
            </p>
        </Card>

        <!-- Funding Path Checklist -->
        <Card variant="paper" className="p-8 border-2 border-earth-brown/20">
            <h3 class="font-literata text-headline-sm text-primary mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">checklist</span> Funding Path
            </h3>
            <ul class="space-y-3 font-body-md text-on-surface-variant">
                {tiers.map((tier) => (
                    <li class={`flex items-center gap-3 ${raised >= tier.cost ? 'text-primary font-medium' : 'opacity-60'}`}>
                        <span class={`material-symbols-outlined text-sm ${raised >= tier.cost ? 'text-primary' : 'text-on-surface-variant'}`}>
                            {raised >= tier.cost ? 'check_circle' : 'radio_button_unchecked'}
                        </span>
                        {raised >= tier.cost ? `Funded: ${tier.name}` : tier.name}
                    </li>
                ))}
            </ul>
        </Card>

        <!-- Add-Ons Section -->
        <Card variant="paper" className={`p-8 border-2 transition-all duration-500 ${raised >= tiers[tiers.length - 1].cost ? 'border-primary shadow-md' : 'border-earth-brown/10 opacity-60 grayscale'}`}>
            <h3 class="font-literata text-headline-sm text-primary mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">shopping_basket</span> Community Extras & Add-Ons
            </h3>
            {raised >= tiers[tiers.length - 1].cost ? (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 font-body-md text-on-surface-variant">
                    {addOns.map((group) => (
                        <div class="flex flex-col gap-2">
                            <span class="font-label-bold text-primary uppercase text-xs">{group.category}</span>
                            <ul class="space-y-1 border-l-2 border-primary/30 pl-4">
                                {group.items.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                    ))}
                </div>
            ) : (
                <p class="text-sm italic text-on-surface-variant">These add-ons will be unlocked once the Composite Double Door Library is funded.</p>
            )}
        </Card>
    </div>

    <!-- Visual Path Element -->
    <div class="w-full max-w-lg mx-auto border-l-4 border-dashed border-earth-brown opacity-10 h-96 absolute left-1/2 -translate-x-1/2 rounded-[100px_0_0_100px] pointer-events-none"></div>
</section>
