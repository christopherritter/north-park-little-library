---
import Card from '../Card.astro';
import Button from '../Button.astro';

interface Props {
    title?: string;
    description?: string;
}

const { 
    title = "Support the Restoration",
    description = "Every contribution brings us closer to a new, weather-proofed library for our community. Choose your way to help below."
} = Astro.props;
---

<section class="min-h-screen relative flex flex-col items-center justify-center py-20 px-margin-mobile md:px-margin-desktop z-20">
    <div class="w-full max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-center bg-white backdrop-blur-sm p-6 md:p-10 rounded-xl sketch-border shadow-lg">
        <div class="relative w-full aspect-square md:aspect-auto md:h-[500px]" id="libraryBox">
            <img alt="Library Box" class="w-full h-full object-contain rounded-lg" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB_aujFeKJh99t8Xu3tLTeVP5-z4inEqj8RHXMBYKKlzs2Kp4yfevJSKEoNZv3DfQPM_f2RVKhqDLX-uLEAIl98fiPtML7RDZi1njbIRW_P21SztyKYas4jgLEIlTutGDNIcGRn8kpKYxLq0HbZ0DAOK9zJomUc3LRiMz87cbhCT_nNLwBMuKfCx7JQjfgOCOObIJ9Px7Eh6-AKcABm3KQe0vOqMSCqFRA7_2ifqKrTIIDqtDbwtCjrIWy8zA-e_nxcTKSD4A2m9KLl" />
            <div id="clearing" class="absolute top-1/2 left-0 w-px h-px scroll-mt-[100px]"></div>
                        </div>
        <div class="flex flex-col gap-6">
            <Card variant="paper" className="p-4 md:p-6 rotate-[1deg]">
                <h2 class="font-literata text-headline-lg-mobile md:text-headline-lg text-primary mb-2">{title}</h2>
                <p class="font-body-md-mobile md:font-body-md text-body-md text-on-surface-variant mb-6">{description}</p>
                <div class="flex flex-col gap-4">
<Button variant="paper" href="https://cash.app/$nplittlelibrary" target="_blank" rel="noopener noreferrer" className="w-full py-3 md:py-4 px-6 rounded flex items-center justify-center gap-3 group font-label-bold text-lg md:text-xl bg-[#006766] text-white border-2 border-earth-brown hover:bg-[#005655] transition-colors">
                            <span class="material-symbols-outlined text-3xl group-hover:rotate-12 transition-transform" data-weight="fill">payments</span>
                            Donate with Cash App
                        </Button>
                        <Button variant="paper" href="https://account.venmo.com/u/NorthParkLittleLibrary" target="_blank" rel="noopener noreferrer" className="w-full py-3 md:py-4 px-6 rounded flex items-center justify-center gap-3 group font-label-bold text-lg md:text-xl bg-[#006766] text-white border-2 border-earth-brown hover:bg-[#005655] transition-colors">
                            <span class="material-symbols-outlined text-3xl group-hover:-translate-y-1 transition-transform" data-weight="fill">payment</span>
                            Send Money with Venmo
                        </Button>
                </div>
            </Card>
        </div>
    </div>
</section>
