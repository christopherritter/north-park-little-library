---
import Card from '../Card.astro';

interface Props {
	title?: string;
	subtitle?: string;
	description?: string;
}

const { 
    title = "Neighborhood Restoration Fund",
    subtitle = "Raising money together to restore our local library.", 
    description = "We’re raising money together to replace our worn-out Little Free Library with something stronger, better, and built to last. This is not a sale—it’s a shared effort to restore a small neighborhood resource that people already use and care about. Every donation moves us to the next level." 
} = Astro.props;
---

<section class="min-h-screen relative flex flex-col items-center justify-start pt-20 px-margin-mobile md:px-margin-desktop pb-20" id="entrance">
    <Card variant="paper" className="text-center mb-12 z-10 p-4 md:p-8 rotate-[1deg] max-w-2xl mt-10">
        <h1 class="font-literata text-headline-lg-mobile md:text-headline-xl text-primary mb-4">{title}</h1>
        <p class="font-body-md-mobile md:font-body-lg text-body-md text-on-surface-variant">{description}</p>
    </Card>
    <div class="relative w-full max-w-4xl mx-auto flex flex-col md:flex-row items-end justify-center gap-10">
        <div class="relative w-64 h-64 md:w-80 md:h-80 z-10">
            <Card variant="paper" className="w-full h-full p-4 pb-12 flex items-center justify-center bg-white">
                <img alt="Little Free Library" class="w-full h-full object-contain" src="/images/little-free-library_132811328.jpg" />
            </Card>
        </div>
        <Card variant="wood" className="p-6 max-w-sm rotate-[-2deg] z-10 relative cursor-pointer">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-8 h-8 bg-surface rounded-full border-2 border-earth-brown flex items-center justify-center shadow-sm">
                <span class="material-symbols-outlined text-earth-brown text-sm" data-weight="fill">push_pin</span>
            </div>
        <a href="#meadow" class="block no-underline">
            <h2 class="font-literata text-headline-sm-mobile md:text-headline-lg-mobile text-on-secondary-fixed mb-2">How Can I Help?</h2>
            <p class="font-body-md text-body-md text-on-secondary-fixed opacity-90">Find out how you can help repair our local library and bring it back to life.</p>
            <div class="mt-4 flex items-center text-primary-container font-label-bold text-label-bold group">
                Learn More <span class="material-symbols-outlined ml-1 group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </div>
        </a>
        </Card>
    </div>
    <div class="absolute bottom-10 animate-bounce cursor-pointer opacity-70">
        <a href="#path"><span class="material-symbols-outlined text-4xl text-earth-brown">stat_minus_2</span></a>
    </div>
</section>
